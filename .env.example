# Environment Variables

# Resend API Key
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# MongoDB connection string (e.g. from MongoDB Atlas)
MONGODB_URI=

# Password for the admin dashboard (used as a Bearer token in /api/orders/list, /api/orders/[id], /api/customers)
DASHBOARD_PASSWORD=Houseofcakes

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Shared secret for Sanity → /api/revalidate webhook (any long random string).
# Paste the same value into the Sanity webhook's "Secret" field.

NEXTAUTH_SECRET=2lgZJT4R2GNvLJOz4Xde5TFrZA6T4Vb3axVFtll4fbg=
NEXTAUTH_URL=http://localhost:3000